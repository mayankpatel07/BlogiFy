@model Post

@{
    ViewData["Title"] = Model.Title;
}
<style>
    .content-wrapper {
        padding: 20px;
        max-width: 1000px;
        margin: 0 auto;
        font-family: sans-serif;
    }
    .feature-image{
        width:100%;
        height:500px;
        object-fit:cover;
        margin-bottom:20px;
    }
</style>

<div class="text-end">
    <a class="btn btn-success my-3" asp-action="Edit" asp-controller="Post" asp-route-id="@Model.Id">Edit Post</a>
    <a class="btn btn-danger my-3 mx-3">Delete Post</a>
</div>

<div class="content-wrapper">
    <h1>@Model.Title</h1>
    <p class="fs-5"><spam class="badge bg-light">By: </spam>  @Model.Author | <spam class="badge bg-light">
        Published On</spam> @Model.PublishedDate.ToString("MMMM dd,yyyy")
    </p>
    <p class ="fs-5"><spam class="badge bg-light">Category: </spam> @Model.Category.Name</p>
    <img src="@Model.FeatureImagePath" alt="@Model.Title" class="feature-image"/>
    <hr />
    <div class="fs-5">@Html.Raw(Model.Content)</div>
    <hr />

    @if (Model.Comments.Any())
    {
        <div id="commentSection">
            @foreach(var comment in Model.Comments)
            {
                <div class="card bg-light mb-3 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@comment.UserName</h5>
                        <p class="caed-text text-muted">@comment.CommentDate.ToString("MMMM dd,yyyy")</p>
                        <p class="card-text">@comment.Content</p>
                    </div>
                </div>
            }
        </div>
        
    }
    else
    {
        <p class="text-muted">No comments yet.Be the first to comment</p>
    }

    <h4>Add a Comment</h4>
    <form id="commentForm">
        <div class="form-group">
            <label for="Username">Name</label>
            <input for="Username" id="Username" name="Username" required class="form-control"/>
        </div>

         <div class="form-group">
            <label for="Content">Content</label>
            <textarea for="Username" id="Content" name="Content" required class="form-control"></textarea>
        </div>

        <button type="submit" class="btn btn-primary mt-2 p-2 rounded">Submit Comment</button>
    </form>

</div>

@section Scripts{
        <script>
        $(document).ready(function() {
            $('#commentForm').on('submit', function(event) {
                event.preventDefault(); 

                // Read form data into variables
                var userName = $('#Username').val();
                var content = $('#Content').val();
                var postId = @Model.Id; // Assuming you want to associate the comment with a specific post

                // Send the data via AJAX
                $.ajax({
                    url: '@Url.Action("AddComment", "Post")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        UserName: userName,
                        Content: content,
                        PostId: postId // Include the post ID if needed
                    }),
                    success: function(response) {
                        $('#commentForm')[0].reset(); // Reset the form

                        // Append the new comment to the comments section
                        $('#commentSection').append(`
                            <div class="card bg-light mb-3 shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title">${response.username}</h5>
                                    <p class="caed-text text-muted">${response.commentDate}</p>
                                    <p class="card-text">${response.content}</p>
                                </div>
                             </div>

                        `);
                    }
                });
            });
        });
    </script>
}