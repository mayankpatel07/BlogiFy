@model PostViewModel
@{
    ViewData["Title"] = "Create Post";
}

<style>
    .content-wrapper{
        padding:20px;
        max-width:1000px;
        margin:0 auto;
        font-family:sans-serif;
    }
</style>
<div class="content-wrapper">
    <div class="row">
        <div class="col-6">
            <h1 class="fw-bold">@ViewData["Title"]</h1>
        </div>
        <div class="col-6 text-end">
            <a class="btn btn-primary">Back To List</a>
        </div>
    </div>

    <hr/>

    <form asp-action="Create" asp-controller="Post" method="post" enctype="multipart/form-data">
        
        <div class="validation-summary">
            <div asp-validation-summary="All" class="fs-4 text-danger"></div>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Post.Title" class="fs-4"></label>
            <input asp-for="Post.Title" class="form-control"/>
            <span class="fs-4 text-danger" asp-validation-for="Post.Title"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Post.CategoryId" class="fs-4">Category</label>
            <select asp-for="Post.CategoryId" asp-items="Model.Categories" class="form-control">
                <option value="">Select Category</option>
            </select>
            <span class="fs-4 text-danger" asp-validation-for="Post.CategoryId"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Post.Author" class="fs-4"></label>
            <input asp-for="Post.Author" class="form-control" />
            <span class="fs-4 text-danger" asp-validation-for="Post.Author"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="Post.Content" class="fs-4"></label>
            <textarea asp-for="Post.Content" class="form-control" rows="5"></textarea>
            <span class="fs-4 text-danger" asp-validation-for="Post.Content"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="FeatureImage" class="fs-4"></label>
            <input asp-for="FeatureImage" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary mt-3">Create</button>
        <a class="btn btn-secondary mt-3">BacK To List</a>
</form>
</div>

@section Scripts{
    <script src="https://cdn.tiny.cloud/1/j9wiaa4vkzt3g9xvtxil3xto76la9huh3mr2fvhdnxe7ie7x/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
    <script>
        tinymce.init({
          selector: 'textarea'
        });
    </script>
}